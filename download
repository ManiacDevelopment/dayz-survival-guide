const illnesses=[{"name": "Cholera", "symptoms": ["Vomiting", "Fever", "Rapid water loss", "Sickness icon"], "causes": ["Drank dirty water", "Drank from unknown bottle", "Used contaminated container"], "cure": ["Tetracycline pills", "Multivitamins if available", "Tiny sips of water", "Tiny bites of food"], "warning": "Do not eat or drink large amounts while sick. Vomiting can cost more water than you gain."}, {"name": "Salmonella / Food Poisoning", "symptoms": ["Vomiting", "Stomach sickness", "Sickness icon"], "causes": ["Ate raw meat", "Ate rotten food", "Ate with bloody hands", "Drank with bloody hands"], "cure": ["Charcoal tablets", "Multivitamins if available", "Eat and drink slowly"], "warning": "Clean your hands or wear gloves before eating after cutting animals."}, {"name": "Common Cold / Influenza", "symptoms": ["Sneezing", "Coughing", "Fever", "Sickness icon"], "causes": ["Got cold", "Got wet", "Low food/water stats", "Close contact with sick player"], "cure": ["Stay warm", "Dry or replace wet clothes", "Tetracycline pills", "Multivitamins", "Eat and drink safely"], "warning": "Warmth and strong food/water stats are part of the cure."}, {"name": "Wound Infection", "symptoms": ["Fever", "Pain sounds", "Blurred vision", "Health loss", "Water loss", "Sickness icon"], "causes": ["Used dirty rag", "Used non-disinfected bandage", "Let bleeding heal untreated"], "cure": ["Early stage: disinfect wound", "Later stage: tetracycline pills", "Use clean bandages going forward"], "warning": "This can become lethal if ignored."}, {"name": "Gas Poisoning / Chemical Exposure", "symptoms": ["Vomiting", "Coughing", "Blood loss", "Health loss", "Sickness icon"], "causes": ["Entered toxic gas zone", "Chemical exposure", "Consumed unsafe chemical liquid"], "cure": ["Leave contaminated area", "Use the correct antidote where required", "Use clean food and water", "Stabilize blood and health"], "warning": "Gas exposure can kill quickly. Escape first, treat second."}, {"name": "Kuru / Brain Prion Disease", "symptoms": ["Laughing", "Shaking hands", "Strange sounds"], "causes": ["Ate human meat", "Ate human fat"], "cure": ["No practical cure", "Avoid cannibalism"], "warning": "This is effectively permanent. Prevention is the real cure."}];
const allSymptoms=[...new Set(illnesses.flatMap(i=>i.symptoms))].sort(),allCauses=[...new Set(illnesses.flatMap(i=>i.causes))].sort();let selectedSymptoms=[],selectedCauses=[];const symptomMount=document.getElementById('symptomChoices'),causeMount=document.getElementById('causeChoices'),resultMount=document.getElementById('illnessResult');function t(s){return window.DayZI18NTranslate?window.DayZI18NTranslate(s):s}function toggle(a,v){return a.includes(v)?a.filter(x=>x!==v):[...a,v]}function causes(){if(!selectedSymptoms.length)return allCauses;return[...new Set(illnesses.filter(i=>selectedSymptoms.some(s=>i.symptoms.includes(s))).flatMap(i=>i.causes))].sort()}function matches(){if(!selectedSymptoms.length&&!selectedCauses.length)return[];return illnesses.map(i=>{const sm=selectedSymptoms.filter(s=>i.symptoms.includes(s)).length,cm=selectedCauses.filter(c=>i.causes.includes(c)).length;return{...i,totalMatches:sm+cm}}).filter(i=>i.totalMatches>0).sort((a,b)=>b.totalMatches-a.totalMatches)}function renderSymptoms(){symptomMount.innerHTML=allSymptoms.map(s=>`<button class="choice-btn ${selectedSymptoms.includes(s)?'active':''}" type="button" data-symptom="${s}">${t(s)}</button>`).join('');symptomMount.querySelectorAll('[data-symptom]').forEach(b=>b.onclick=()=>{selectedSymptoms=toggle(selectedSymptoms,b.dataset.symptom);selectedCauses=selectedCauses.filter(c=>causes().includes(c));renderAll()})}function renderCauses(){causeMount.innerHTML=causes().map(c=>`<button class="choice-btn ${selectedCauses.includes(c)?'active':''}" type="button" data-cause="${c}">${t(c)}</button>`).join('');causeMount.querySelectorAll('[data-cause]').forEach(b=>b.onclick=()=>{selectedCauses=toggle(selectedCauses,b.dataset.cause);renderAll()})}function renderResults(){const m=matches();if(!m.length){resultMount.innerHTML=`<p class="empty-state">${t('Select symptoms to begin.')}</p>`;return}resultMount.innerHTML=`<div class="result-grid">${m.map(x=>`<div class="result-card"><span class="match-score">${t('Match')}: ${x.totalMatches} ${t(x.totalMatches===1?'point':'points')}</span><h3>${t(x.name)}</h3><p><strong>${t('Likely causes')}:</strong> ${x.causes.map(t).join(', ')}</p><p><strong>${t('Symptoms')}:</strong> ${x.symptoms.map(t).join(', ')}</p><h4>${t('Cure')}</h4><ul>${x.cure.map(y=>`<li>${t(y)}</li>`).join('')}</ul><h4>${t('Important')}</h4><p>${t(x.warning)}</p></div>`).join('')}</div>`}function renderAll(){if(symptomMount&&causeMount&&resultMount){renderSymptoms();renderCauses();renderResults()}}window.renderAll=renderAll;renderAll();
